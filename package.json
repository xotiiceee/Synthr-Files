{
  "name": "synthr-monorepo",
  "version": "1.0.0",
  "description": "Synthr — AI Design Tools Directory + Pulse — X marketing automation",
  "private": true,
  "scripts": {
    "pulse:hosted": "pnpm --filter pulse hosted",
    "pulse:build:ui": "pnpm --filter pulse build:ui",
    "pulse:test": "pnpm --filter pulse test",
    "pulse:lint": "pnpm --filter pulse lint",
    "synthr:dev": "pnpm --filter synthr dev",
    "synthr:build": "pnpm --filter synthr build",
    "synthr:start": "pnpm --filter synthr start",
    "generate": "pnpm --filter @synthr/marketing generate"
  }
}
