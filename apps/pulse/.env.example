# ===================================================
# PULSE - Standalone X Automation Platform
# Copy to .env and fill in your keys
# After filling in, run: npm run test-config
# ===================================================
#
# SETUP CHECKLIST:
#   1. Choose 1 LLM provider
#   2. Choose 1 search provider
#   3. Add X credentials and OAuth credentials
#   4. Run: npm run test-config
#   5. Run: npm run dry-run

# This file tracks variables consumed by the codebase.
# The production VPS .env is the source of truth for actual values.
# When adding a new env var to source code, add it here too.

# ===================================================
# REQUIRED: LLM Provider (choose 1)
# ===================================================
# Provider comparison:
#   Groq       — usage-based hosted inference, Llama 3.3 70B, fast
#   OpenAI     — ~$0.15/1K requests, GPT-4o-mini, best all-around
#   Anthropic  — ~$0.25/1K requests, Claude, best conversational tone
#   OpenRouter — Pay-per-use, access to 100+ models
#   Ollama     — runs locally (requires GPU)

LLM_PROVIDER=groq

# Groq (recommended for local development)
# 1. Go to https://console.groq.com
# 2. Sign up with Google or GitHub
# 3. Click "API Keys" in sidebar → "Create API Key"
# 4. Copy the key (starts with gsk_)
GROQ_API_KEY=

# OpenAI (paid — best quality)
# Get key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Anthropic (paid — best conversational tone)
# Get key at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# OpenRouter (pay-per-use, multiple models)
# Get key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# Ollama (local — requires GPU + `ollama serve` running)
# OLLAMA_URL=http://localhost:11434/api/chat

# Override default model (leave blank for provider default)
LLM_MODEL=

# Max LLM requests per hour
LLM_RATE_LIMIT=200

# ===================================================
# REQUIRED: Search Provider (choose 1)
# ===================================================
# Provider comparison:
#   Serper  — Google results
#   Brave   — privacy-focused
#   SerpAPI — detailed Google results

SEARCH_PROVIDER=serper

# Serper
# 1. Go to https://serper.dev
# 2. Sign up and create an API key
# 3. Copy your API key from the dashboard
SERPER_API_KEY=

# Brave Search
# Get key at https://brave.com/search/api
# BRAVE_API_KEY=

# SerpAPI
# Get key at https://serpapi.com
# SERPAPI_API_KEY=

# ===================================================
# OPTIONAL: Legacy X app tokens
# ===================================================

# --- X/Twitter (most common) ---
# 1. Go to https://developer.x.com/en/portal/dashboard
# 2. Create a new App (or select existing)
# 3. Go to "Keys and tokens" tab
# 4. You need ALL FOUR values below:
X_API_KEY=                    # API Key (Consumer Key)
X_API_SECRET=                 # API Key Secret (Consumer Secret)
X_ACCESS_TOKEN=               # Access Token
X_ACCESS_TOKEN_SECRET=        # Access Token Secret
X_MONTHLY_POST_LIMIT=1500     # Set to your approved X API monthly write capacity
# Note: choose an X API tier that supports your expected automation volume

# --- Reddit (optional) ---
# 1. Go to https://www.reddit.com/prefs/apps
# 2. Click "create another app" → select "script" type
# 3. Set redirect URI to http://localhost
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# --- Discord (optional) ---
# 1. Go to https://discord.com/developers/applications
# 2. New Application → Bot → Copy token
# 3. Enable "Message Content Intent" under Privileged Gateway Intents
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_IDS=          # Comma-separated channel IDs

# ===================================================
# REQUIRED (hosted deployment): Server
# ===================================================
HOSTED_PORT=3457
PULSE_URL=https://app.your-pulse-domain.com
HOSTED_DB_PATH=/home/deploy/pulse/data/hosted.db
PULSE_HEART_PATH=/home/deploy/pulse/data/pulse-heart.json

# Optional legacy/rollback provider access.
CLAWNET_API_URL=https://api.claw-net.org
CLAWNET_API_KEY=              # Optional cn- key for legacy ClawNet-backed features

# Standalone launch posture. Roll back to clawnet/legacy only during migration.
AUTH_PROVIDER=firstparty      # clawnet|firstparty
BILLING_PROVIDER=stripe       # clawnet|stripe
STRIPE_WEBHOOK_SECRET=        # required when BILLING_PROVIDER=stripe; Stripe endpoint secret for /webhooks/stripe
SCHEDULER_MODE=durable        # legacy|durable
PULSE_DURABLE_SCHEDULER_WRITES=true  # required by strict customer launch
PULSE_ALLOW_FOLLOW_CHURN=     # leave empty for customer launch
PULSE_CUSTOMER_LAUNCH=false   # set true only for final cutover checks

# ===================================================
# REQUIRED (hosted deployment): Security
# ===================================================
TENANT_ENCRYPTION_KEY=        # hex key for multi-brand encryption
                              # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=                # Admin/operator access key
                              # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_EMAIL=                  # Admin notification email
REQUIRE_PIN=true              # Require PIN for dashboard access
# ADMIN_PIN=                  # Set if using PIN auth

# ===================================================
# REQUIRED (customer launch): Email and user-facing X OAuth
# ===================================================
RESEND_API_KEY=               # Required for customer launch account/security emails
RESEND_FROM=Pulse <notifications@your-pulse-domain.com>
RESEND_DOMAIN=updates.your-pulse-domain.com  # For weekly insights sender
PULSE_SUPPORT_EMAIL=support@your-pulse-domain.com
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=

# ===================================================
# OPTIONAL: GitHub OAuth
# ===================================================
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# Callback URL is derived from PULSE_URL:
#   ${PULSE_URL}/auth/github/callback
# If GITHUB_CALLBACK_URL is configured, both GitHub OAuth credentials are
# required by production readiness.

# ===================================================
# OPTIONAL: Panel Security
# ===================================================
# Set a token to protect the web dashboard (required for remote access)
# PULSE_PANEL_TOKEN=your-secret-token-here
# PULSE_PANEL_PORT=3456
# PULSE_DISCORD_WEBHOOK=     # Escalation webhook
# PULSE_SLACK_WEBHOOK=       # Escalation webhook

# ===================================================
# REQUIRED (hosted deployment): Soma Heart Persistence
# ===================================================
# Secret used to encrypt the Pulse operator heart at rest.
# Generate a strong random string (e.g., openssl rand -base64 32).
# Strict customer launch also requires PULSE_HEART_PATH above to point at an
# existing loadable heart file.
PULSE_HEART_SECRET=
                              # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"

# ===================================================
# OPTIONAL: x402 Inline Payments
# ===================================================
# Enables HTTP 402 / x402 payment flow for callers without ClawNet credits.
# If unset, out-of-credit callers receive a plain JSON 402.
X402_TREASURY_ADDRESS=   # Base mainnet USDC address that receives payments (add to VPS .env)
X402_FACILITATOR_URL=    # Optional — defaults to https://x402.org/facilitate
