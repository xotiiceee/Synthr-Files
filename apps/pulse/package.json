{
  "name": "pulse",
  "version": "1.0.0",
  "description": "Pulse — standalone X marketing automation for teams and agencies",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "audit:all": "pnpm audit && pnpm audit --prod && pnpm --filter ui audit && pnpm --filter ui audit --prod",
    "build:ui": "pnpm --filter ui build",
    "setup": "tsx scripts/setup.ts",
    "start": "tsx scripts/run.ts",
    "dry-run": "tsx scripts/run.ts --dry-run",
    "report": "tsx scripts/report.ts",
    "calendar": "tsx scripts/content-calendar.ts",
    "test-config": "tsx scripts/test-config.ts",
    "check:production": "tsx scripts/check-production-readiness.ts",
    "check:customer-launch": "PULSE_CUSTOMER_LAUNCH=true tsx scripts/check-production-readiness.ts",
    "check:production-deploy-patch": "tsx scripts/verify-production-deploy-pin-patch.ts",
    "check:launch-preflight": "npm run audit:all && npm run lint && npm run typecheck && npm run test && npm run build:ui && npm run check:production-deploy-patch",
    "measure:durable-jobs": "tsx scripts/measure-durable-jobs.ts",
    "backup:production": "bash scripts/backup-production.sh",
    "restore:production": "bash scripts/restore-production-backup.sh",
    "dashboard": "tsx src/analytics/web-dashboard.ts",
    "panel": "tsx src/panel/server.ts",
    "hosted": "pnpm tsx hosted/server.ts",
    "stop": "tsx scripts/stop.ts",
    "resume": "tsx scripts/resume.ts",
    "crm": "tsx scripts/crm.ts",
    "brands": "tsx scripts/brands.ts",
    "videos": "tsx scripts/video-scripts.ts",
    "emails": "tsx scripts/email-sequences.ts",
    "queue": "tsx scripts/queue.ts",
    "insights": "tsx scripts/insights.ts",
    "research": "tsx scripts/research.ts",
    "repurpose": "tsx scripts/repurpose.ts",
    "landing-page": "tsx scripts/landing-page.ts",
    "lead-magnets": "tsx scripts/lead-magnets.ts",
    "competitors": "tsx scripts/competitor-report.ts",
    "mentions": "tsx scripts/mentions.ts",
    "autopost": "tsx scripts/autopost.ts",
    "voice-calibrate": "tsx scripts/voice-calibrate.ts",
    "ci": "npm run lint && npm run format:check && npm run typecheck && npm run test && npm run build:ui"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@octokit/rest": "^22.0.1",
    "better-sqlite3": "^12.10.1",
    "dotenv": "^17.4.2",
    "hono": "^4.12.23",
    "soma-heart": "^1.0.0",
    "tsx": "^4.22.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
